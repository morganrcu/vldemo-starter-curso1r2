    ],
    "rationale": "Scoring crediticio automatizado para aprobación de préstamos al consumo: sistema de IA de alto riesgo (decisiones que afectan al acceso a crédito de personas físicas)."
  },
  "risks": [
    {
      "id": "risk.unfair-credit-exclusion",
      "domain": "fairness",
      "title": "Unfair Credit Exclusion of Minorities",
      "rationale": "El modelo puede excluir injustamente a grupos protegidos al heredar patrones históricos de discriminación (sexo, edad)."
    },
    {
      "id": "risk.data-governance",
      "domain": "data",
      "title": "Poisoned Data from Feedback Loops",
      "rationale": "Las decisiones sesgadas realimentan el reentrenamiento (profecía autocumplida), degradando la calidad y representatividad del dato."
    },
    {
      "id": "risk.opacity",
      "domain": "transparency",
      "title": "Automated Decisions without Explainability",
      "rationale": "Decisiones automatizadas sin exactitud mínima defendible comprometen la explicabilidad y el derecho a una decisión justa."
    },
    {
      "id": "risk.age-discrimination",
      "domain": "fairness",
      "title": "Age-based Credit Discrimination",
      "rationale": "El KAG detecta que la edad es un proxy fuerte: el modelo puede discriminar por grupo de edad aunque se haya mitigado el sexo. Riesgo EMERGENTE (no en el registro inicial)."
    }
  ],
